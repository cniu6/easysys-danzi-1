  "services": [
    {
      "id": "s1",
      "image": "/images/service-prewedding.jpg",
      "title": {
        "zh": "婚纱旅拍",
        "en": "PRE-WEDDING",
        "fr": "PRÉ-MARIAGE"
      },
      "description": {
        "zh": "通过旅行，拍下美丽的巴黎婚纱照。巴黎是浪漫之都、爱情之城，是海外婚纱旅拍的绝佳选择。我们为您提供专业的婚纱拍摄方案。",
        "en": "You can get beautiful Paris pre-wedding photos through travelling. Paris is the best choice for special travelling pre-wedding photos — the City of Love and the symbol of Romance. We provide professional shooting plans for you.",
        "fr": "Obtenez de magnifiques photos de pré-mariage à Paris en voyage. Paris, ville de l'amour et symbole de romantisme, est le meilleur choix. Nous proposons des plans de shooting professionnels."
      },
      "order": 1,
      "href": "/gallery/paris"
    },
    {
      "id": "s2",
      "image": "/images/service-wedding.jpg",
      "title": {
        "zh": "婚礼纪录",
        "en": "WEDDING",
        "fr": "MARIAGE"
      },
      "description": {
        "zh": "爱与热情驱动我们的一切。共情是点燃一切的火焰。每一对伴侣都值得拥有一场神奇的拍摄或婚礼体验。让你们的日子精彩，是我们的首要任务。我们的摄影风格时尚、永恒，充满浪漫气息。",
        "en": "Love and passion inspire everything we do. Empathy is the flame that lights it up. Every couple deserves a magical photo shoot or wedding experience. Making your day amazing is our top priority. Our photography style is chic and timeless with a romantic vibe.",
        "fr": "L'amour et la passion inspirent tout ce que nous faisons. L'empathie est la flamme qui l'allume. Chaque couple mérite une séance photo ou un mariage magique. Notre style est chic, intemporel et romantique."
      },
      "order": 2,
      "href": "/gallery/chateau"
    }
  ],
