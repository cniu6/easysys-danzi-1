# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env 文件：本项目按需求一并提交（含 .env.local）
# 如需私密环境变量，请改用服务器侧配置，勿依赖公开仓库保密
.env*
!.env.example
!.env.local

# 临时抓取/调试大文件
scripts/_mono-*.html
scripts/*.html
!scripts/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
