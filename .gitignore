# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# 临时抓取/调试大文件
scripts/_mono-*.html
scripts/*.html
!scripts/.gitkeep

# 从官网扒下的原始大图备份（体积大，运行不依赖）
public/images/mono/


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
